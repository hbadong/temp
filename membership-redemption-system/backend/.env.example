# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=membership_redemption

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# 短信服务配置 (阿里云)
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=会员兑换系统
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxx

# 第三方平台配置
IQIYI_APP_ID=your_iqiyi_app_id
IQIYI_APP_KEY=your_iqiyi_app_key
IQIYI_API_URL=https://api.iqiyi.com

YOUKU_APP_ID=your_youku_app_id
YOUKU_APP_KEY=your_youku_app_key
YOUKU_API_URL=https://api.youku.com

TENCENT_APP_ID=your_tencent_app_id
TENCENT_APP_KEY=your_tencent_app_key
TENCENT_API_URL=https://api.vip.qq.com

# 服务器配置
PORT=8000
NODE_ENV=development

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs
