{
  "name": "qiming-backend",
  "version": "1.0.0",
  "description": "起名平台系统 - 后端服务",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step for Node.js'",
    "lint": "eslint src/ --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "init:db": "node scripts/initDb.js",
    "import": "node scripts/importData.js",
    "export": "node scripts/exportData.js",
    "backup": "node scripts/backup.js backup",
    "restore": "node scripts/backup.js restore"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "lodash-es": "^4.17.21",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "pinyin": "^4.0.0",
    "redis": "^4.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.0"
  }
}
